{
  "name": "flobby",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:https": "VITE_HTTPS=true vite --host 0.0.0.0 --port 5174",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tiled:generate": "node scripts/generate-tiled-levels.ts",
    "tiled:validate": "node scripts/validate-tiled-levels.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
